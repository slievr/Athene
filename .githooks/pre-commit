#!/usr/bin/env bash
# Pre-commit hook: run clippy on staged Rust changes.
# Install once per clone: git config core.hooksPath .githooks

set -euo pipefail

# Check whether any staged files live under athene/
if git diff --cached --name-only | grep -q '^athene/'; then
  echo "🔍 Running cargo clippy on athene/ ..."
  (
    cd "$(git rev-parse --show-toplevel)/athene"
    cargo clippy --workspace --all-targets -- -D warnings
  )
fi
