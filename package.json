{
  "name": "athene",
  "version": "0.1.0",
  "private": true,
  "description": "Orchestrate parallel AI coding agents across any runtime, any repo, any issue tracker",
  "license": "MIT",
  "engines": {
    "node": ">=20.18.3"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @made-by-moonlight/athene-web dev",
    "dev:packages": "pnpm -r --parallel --filter '!@made-by-moonlight/athene-web' --filter '!@made-by-moonlight/athene-cli' dev",
    "dev:cli": "concurrently --names tsc,node -c blue,green 'pnpm --filter @made-by-moonlight/athene-cli dev:watch' 'pnpm dev:start'",
    "dev:start": "node --watch packages/cli/dist/index.js start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter '!@made-by-moonlight/athene-web' test",
    "test:integration": "pnpm --filter @made-by-moonlight/athene-integration-tests test:integration",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && node scripts/publish.mjs",
    "prepare": "husky",
    "postinstall": "node scripts/rebuild-node-pty.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "concurrently": "^9.2.1",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^15.5.15",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.55.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.0",
      "axios>follow-redirects": "^1.16.0",
      "external-editor>tmp": "0.2.4"
    }
  }
}
