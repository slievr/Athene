{
  "name": "@made-by-moonlight/athene-plugin-adapter-shim",
  "version": "0.1.0",
  "description": "TypeScript adapter shim: wraps a plugin and speaks the Go engine JSON-RPC 2.0 protocol",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "athene-plugin-shim": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/slievr/Athene.git",
    "directory": "packages/plugins/adapter-shim"
  },
  "homepage": "https://github.com/slievr/Athene",
  "bugs": {
    "url": "https://github.com/slievr/Athene/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@made-by-moonlight/athene-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
